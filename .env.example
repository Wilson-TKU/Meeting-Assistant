# LLM — 直接指向 model server
#
# LLM_MODEL：直接填 model name，不需要 provider prefix
#
# --- 範例 ---
# vLLM（自架，OpenAI-compatible）：
#   LLM_MODEL=Qwen/Qwen3-4B
#   LLM_BASE_URL=http://host.docker.internal:8002
#   LLM_API_KEY=no-key
#
# Ollama（本地）：
#   LLM_MODEL=qwen3:4b
#   LLM_BASE_URL=http://host.docker.internal:11434
#   LLM_API_KEY=ollama   # 非空字串即可；空字串會被 LiteLLM fallback 去找 OPENAI_API_KEY
#
# OpenAI：
#   LLM_MODEL=gpt-4o
#   LLM_BASE_URL=
#   LLM_API_KEY=sk-...
#
# Anthropic：
#   LLM_MODEL=anthropic/claude-sonnet-4-6
#   LLM_BASE_URL=
#   LLM_API_KEY=sk-ant-...
#
# Gemini：
#   LLM_MODEL=gemini/gemini-2.0-flash
#   LLM_BASE_URL=
#   LLM_API_KEY=...

LLM_MODEL=Qwen/Qwen3-4B
LLM_API_KEY=sk-dummy-key
LLM_BASE_URL=http://host.docker.internal:8002

# STT — 外部 STT service URL（預設：同 Docker 網路內的 stt_service）
# 若 STT 跑在另一台裝置，改成該裝置的 IP/hostname
STT_SERVICE_URL=http://stt_service:8080

# STT Configuration
STT_MODEL=large-v3           # tiny, base, small, medium, large-v2, large-v3
STT_DEVICE=cuda              # cpu | cuda
STT_COMPUTE_TYPE=float16     # float16（GPU 推薦）| int8_float16 | int8（CPU 用）| float32
STT_WORKERS=2                # STT service 同時載入的 model instance 數

# Celery — 分開的 STT / LLM worker pool
STT_CONCURRENCY=2            # STT worker 並發數，建議與 STT_WORKERS 一致
LLM_CONCURRENCY=4            # LLM worker 並發數，視 LLM server 容量調整

# Storage
LOCAL_STORAGE_PATH=./data/storage

# Database
DATABASE_URL=sqlite:///./data/meeting_assistant.db

# Redis
REDIS_URL=redis://localhost:6379/0
